generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Player {
  id                              Int                              @id @default(autoincrement())
  username                        String                           @unique @db.VarChar(50)
  passwordHash                    String                           @db.VarChar(255)
  money                           Int                              @default(0)
  health                          Int                              @default(100)
  hunger                          Float                            @default(100)
  thirst                          Float                            @default(100)
  rank                            Int                              @default(1)
  xp                              Int                              @default(0)
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  lastTickAt                      DateTime                         @default(now())
  currentCountry                  String                           @default("netherlands") @db.VarChar(50)
  fbiHeat                         Int                              @default(0)
  wantedLevel                     Int                              @default(0)
  travelingTo                     String?                          @db.VarChar(50)
  travelRoute                     String?                          @db.LongText
  currentTravelLeg                Int                              @default(0)
  travelStartedAt                 DateTime?
  killCount                       Int                              @default(0)
  isHunted                        Boolean                          @default(false)
  hitCount                        Int                              @default(0)
  allowMessages                   Boolean                          @default(true)
  avatar                          String?                          @default("default_1") @db.VarChar(100)
  banReason                       String?                          @db.Text
  bannedUntil                     DateTime?
  email                           String?                          @db.VarChar(255)
  emailFriendAccepted             Boolean                          @default(true)
  emailFriendRequest              Boolean                          @default(true)
  emailVerified                   Boolean                          @default(false)
  mollieCustomerId                String?                          @db.VarChar(255)
  mollieSubscriptionId            String?                          @db.VarChar(255)
  stripeCustomerId                String?                          @db.VarChar(255)
  intensiveCareUntil              DateTime?
  inventory_slots_used            Int                              @default(0)
  isBanned                        Boolean                          @default(false)
  isVip                           Boolean                          @default(false)
  jailRelease                     DateTime?
  lastAmmoPurchaseAt              DateTime?
  lastAvatarChange                DateTime?
  lastHospitalVisit               DateTime?
  lastUsernameChange              DateTime?
  max_inventory_slots             Int                              @default(5)
  notifyFriendAccepted            Boolean                          @default(true)
  notifyFriendRequest             Boolean                          @default(true)
  premiumCredits                  Int                              @default(0)
  preferredLanguage               String                           @default("nl") @db.VarChar(5)
  reputation                      Int                              @default(0)
  resetPasswordToken              String?                          @db.VarChar(255)
  resetPasswordTokenExpiry        DateTime?
  hitProtectionExpiresAt          DateTime?
  verificationToken               String?                          @db.VarChar(255)
  verificationTokenExpiry         DateTime?
  vipExpiresAt                    DateTime?
  lastProstituteRecruitment       DateTime?
  drugHeat                        Int                              @default(0)
  autoCollectDrugs                Boolean                          @default(false)
  lastDrugActionAt                DateTime?                        @db.DateTime(0)
  aircraft                        Aircraft[]
  ammoFactories                   AmmoFactory[]
  ammoInventory                   AmmoInventory[]
  aviationLicense                 AviationLicense?
  bankAccount                     BankAccount?
  casinoOwnerships                CasinoOwnership[]
  crewJoinRequests                CrewJoinRequest[]
  crewMembership                  CrewMember?
  crewMessages                    CrewMessage[]
  crimeAttempts                   CrimeAttempt[]
  creditEntitlements              PlayerCreditEntitlement[]
  creditTransactions              PlayerCreditTransaction[]
  crypto_holdings                 crypto_holdings[]
  crypto_leaderboard_rewards      crypto_leaderboard_rewards[]
  crypto_mission_progress         crypto_mission_progress[]
  crypto_orders                   crypto_orders[]
  crypto_transactions             crypto_transactions[]
  receivedMessages                DirectMessage[]                  @relation("ReceivedMessages")
  sentMessages                    DirectMessage[]                  @relation("SentMessages")
  drugProductions                 DrugProduction[]
  eventParticipations             EventParticipation[]
  friendRequestsReceived          Friendship[]                     @relation("FriendReceived")
  friendRequestsSent              Friendship[]                     @relation("FriendRequests")
  gameEventProgress               GameEventParticipantProgress[]
  gameEventRewardClaims           GameEventRewardClaim[]
  garages                         Garage[]
  gymStats                        GymStats?
  hitsCompleted                   HitList[]                        @relation("HitKiller")
  hitsPlaced                      HitList[]                        @relation("HitPlacer")
  hitsTarget                      HitList[]                        @relation("HitTarget")
  inventory                       Inventory[]
  inventoryUpgrades               InventoryUpgrades[]
  jobAttempts                     JobAttempt[]
  marinas                         Marina[]
  nightclubAssignments            NightclubProstituteAssignment[]
  nightclubSeasonRewards          NightclubSeasonReward[]
  nightclubs                      NightclubVenue[]
  activities                      PlayerActivity[]
  paymentTransactions             PaymentTransaction[]
  playerBackpack                  PlayerBackpack?
  devices                         PlayerDevice[]
  player_notification_preferences player_notification_preferences?
  premiumPopupSeen                PlayerPremiumPopupSeen[]
  security                        PlayerSecurity?
  selectedVehicle                 PlayerSelectedVehicle?
  playerTools                     PlayerTools[]
  profileLikesGiven               ProfileLike[]                    @relation("ProfileLikesGiven")
  profileLikesReceived            ProfileLike[]                    @relation("ProfileLikesReceived")
  productionMaterials             ProductionMaterial[]
  properties                      Property[]
  prostitutes                     Prostitute[]
  prostitutionAchievements        ProstitutionAchievement[]
  leaderboardEntries              ProstitutionLeaderboard[]
  prostitutionProtectionInsurance ProstitutionProtectionInsurance?
  rivalriesAsPlayer               ProstitutionRivalry[]            @relation("RivalriesAsPlayer")
  rivalriesAsRival                ProstitutionRivalry[]            @relation("RivalriesAsRival")
  ownedRedLightDistricts          RedLightDistrict[]
  sabotageAsAttacker              SabotageAction[]                 @relation("SabotageAttacker")
  sabotageAsVictim                SabotageAction[]                 @relation("SabotageVictim")
  shootingStats                   ShootingRangeStats?
  toolLoadouts                    ToolLoadouts[]
  toolTransfers                   ToolTransfers[]
  vehicleInventory                VehicleInventory[]
  vehicles                        Vehicle[]
  weaponInventory                 WeaponInventory[]

  @@index([username])
  @@map("players")
}

model PlayerBackpack {
  id          Int      @id @default(autoincrement())
  playerId    Int      @unique
  backpackId  String   @db.VarChar(50)
  purchasedAt DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("player_backpacks")
}

model WorldEvent {
  id        Int      @id @default(autoincrement())
  eventKey  String   @db.VarChar(100)
  params    String   @db.LongText
  playerId  Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("world_events")
}

model GameEventTemplate {
  id                 Int                 @id @default(autoincrement())
  key                String              @unique @db.VarChar(100)
  category           String              @db.VarChar(50)
  eventType          String              @db.VarChar(50)
  titleNl            String              @db.VarChar(255)
  titleEn            String              @db.VarChar(255)
  shortDescriptionNl String?             @db.VarChar(255)
  shortDescriptionEn String?             @db.VarChar(255)
  descriptionNl      String?             @db.Text
  descriptionEn      String?             @db.Text
  icon               String?             @db.VarChar(100)
  bannerImage        String?             @db.VarChar(255)
  configSchemaJson   String?             @db.LongText
  uiSchemaJson       String?             @db.LongText
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  schedules          GameEventSchedule[]
  liveEvents         GameLiveEvent[]

  @@index([category, eventType, isActive])
  @@map("game_event_templates")
}

model GameEventSchedule {
  id              Int               @id @default(autoincrement())
  templateId      Int
  scheduleType    String            @db.VarChar(50)
  intervalMinutes Int?
  durationMinutes Int?
  cronExpression  String?           @db.VarChar(100)
  startWindowUtc  String?           @db.VarChar(20)
  endWindowUtc    String?           @db.VarChar(20)
  cooldownMinutes Int?
  enabled         Boolean           @default(true)
  weight          Int               @default(1)
  lastTriggeredAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  template        GameEventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "ges_template_fk")

  @@index([templateId, enabled])
  @@index([scheduleType, enabled])
  @@map("game_event_schedules")
}

model GameLiveEvent {
  id                   Int                            @id @default(autoincrement())
  templateId           Int
  status               String                         @default("draft") @db.VarChar(30)
  startedAt            DateTime?
  endsAt               DateTime?
  resolvedAt           DateTime?
  configJson           String?                        @db.LongText
  stateJson            String?                        @db.LongText
  announcementJson     String?                        @db.LongText
  scopeJson            String?                        @db.LongText
  createdByAdminId     Int?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @default(now()) @updatedAt
  leaderboardSnapshots GameEventLeaderboardSnapshot[]
  participants         GameEventParticipantProgress[]
  rewardClaims         GameEventRewardClaim[]
  rewardRules          GameEventRewardRule[]
  modifiers            GameLiveEventModifier[]
  createdByAdmin       Admin?                         @relation("AdminCreatedGameEvents", fields: [createdByAdminId], references: [id], map: "gle_admin_fk")
  template             GameEventTemplate              @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "gle_template_fk")

  @@index([templateId, status])
  @@index([status, startedAt, endsAt])
  @@index([createdByAdminId])
  @@map("game_live_events")
}

model GameLiveEventModifier {
  id             Int           @id @default(autoincrement())
  liveEventId    Int
  targetSystem   String        @db.VarChar(50)
  modifierKey    String        @db.VarChar(100)
  operation      String        @db.VarChar(30)
  valueJson      String?       @db.LongText
  conditionsJson String?       @db.LongText
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  liveEvent      GameLiveEvent @relation(fields: [liveEventId], references: [id], onDelete: Cascade, map: "glem_live_fk")

  @@index([liveEventId, targetSystem])
  @@map("game_live_event_modifiers")
}

model GameEventParticipantProgress {
  id                 Int           @id @default(autoincrement())
  liveEventId        Int
  playerId           Int?
  subjectType        String        @default("player") @db.VarChar(30)
  subjectKey         String        @db.VarChar(100)
  progressJson       String?       @db.LongText
  score              Float         @default(0)
  rank               Int?
  qualified          Boolean       @default(false)
  lastContributionAt DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @default(now()) @updatedAt
  liveEvent          GameLiveEvent @relation(fields: [liveEventId], references: [id], onDelete: Cascade, map: "gepp_live_fk")
  player             Player?       @relation(fields: [playerId], references: [id], map: "gepp_player_fk")

  @@unique([liveEventId, subjectType, subjectKey], map: "gepp_live_subject_key_uq")
  @@index([liveEventId, rank], map: "gepp_live_rank_idx")
  @@index([liveEventId, score], map: "gepp_live_score_idx")
  @@index([playerId], map: "gepp_player_idx")
  @@map("game_event_participant_progress")
}

model GameEventLeaderboardSnapshot {
  id          Int           @id @default(autoincrement())
  liveEventId Int
  boardType   String        @db.VarChar(50)
  snapshotAt  DateTime      @default(now())
  entriesJson String        @db.LongText
  createdAt   DateTime      @default(now())
  liveEvent   GameLiveEvent @relation(fields: [liveEventId], references: [id], onDelete: Cascade, map: "gels_live_fk")

  @@index([liveEventId, boardType, snapshotAt], map: "gels_live_board_snap_idx")
  @@map("game_event_leaderboard_snapshots")
}

model GameEventRewardRule {
  id                Int                    @id @default(autoincrement())
  liveEventId       Int
  triggerType       String                 @db.VarChar(50)
  triggerConfigJson String?                @db.LongText
  rewardsJson       String                 @db.LongText
  sortOrder         Int                    @default(0)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @default(now()) @updatedAt
  claims            GameEventRewardClaim[]
  liveEvent         GameLiveEvent          @relation(fields: [liveEventId], references: [id], onDelete: Cascade, map: "gerr_live_fk")

  @@index([liveEventId, isActive, sortOrder], map: "gerr_live_active_sort_idx")
  @@map("game_event_reward_rules")
}

model GameEventRewardClaim {
  id                 Int                  @id @default(autoincrement())
  liveEventId        Int
  rewardRuleId       Int?
  playerId           Int
  grantedRewardsJson String               @db.LongText
  claimedAt          DateTime?
  deliveryStatus     String               @default("pending") @db.VarChar(30)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now()) @updatedAt
  liveEvent          GameLiveEvent        @relation(fields: [liveEventId], references: [id], onDelete: Cascade, map: "gerc_live_fk")
  player             Player               @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "gerc_player_fk")
  rewardRule         GameEventRewardRule? @relation(fields: [rewardRuleId], references: [id], map: "gerc_rule_fk")

  @@index([liveEventId, playerId], map: "gerc_live_player_idx")
  @@index([playerId, deliveryStatus], map: "gerc_player_delivery_idx")
  @@index([rewardRuleId], map: "gerc_rule_fk")
  @@map("game_event_reward_claims")
}

model Vehicle {
  id                    Int                    @id @default(autoincrement())
  playerId              Int
  vehicleType           String                 @db.VarChar(50)
  fuel                  Int                    @default(100)
  maxFuel               Int                    @default(100)
  createdAt             DateTime               @default(now())
  isBroken              Boolean                @default(false)
  armor                 Int                    @default(50)
  cargo                 Int                    @default(50)
  condition             Float                  @default(100)
  speed                 Int                    @default(50)
  stealth               Int                    @default(50)
  updatedAt             DateTime               @updatedAt
  playerSelectedVehicle PlayerSelectedVehicle?
  player                Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("vehicles")
}

model PlayerSelectedVehicle {
  id          Int      @id @default(autoincrement())
  playerId    Int      @unique
  vehicleId   Int      @unique
  selectedFor String   @default("robbery") @db.VarChar(50)
  selectedAt  DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([vehicleId])
  @@map("player_selected_vehicles")
}

model CrimeAttempt {
  id                   Int       @id @default(autoincrement())
  playerId             Int
  crimeId              String    @db.VarChar(50)
  success              Boolean
  reward               Int       @default(0)
  xpGained             Int       @default(0)
  jailed               Boolean   @default(false)
  jailTime             Int       @default(0)
  vehicleId            Int?
  createdAt            DateTime  @default(now())
  appealedAt           DateTime?
  cargoUsed            Int       @default(0)
  lootStolen           Int       @default(0)
  outcome              String    @default("success") @db.VarChar(50)
  outcomeFail          String?   @db.Text
  toolConditionBefore  Int?
  toolDamageSustained  Int       @default(0)
  usedToolId           String?   @db.VarChar(50)
  vehicleCargoBonus    Float     @default(1)
  vehicleConditionUsed Float?
  vehicleSpeedBonus    Float     @default(1)
  vehicleStealthBonus  Float     @default(1)
  player               Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
  @@map("crime_attempts")
}

model JobAttempt {
  id          Int      @id @default(autoincrement())
  playerId    Int
  jobId       String   @db.VarChar(50)
  earnings    Int
  xpGained    Int
  completedAt DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([playerId, jobId])
  @@index([completedAt])
  @@map("job_attempts")
}

model Property {
  id              Int                   @id @default(autoincrement())
  playerId        Int?
  propertyType    String                @db.VarChar(50)
  purchasePrice   Int
  upgradeLevel    Int                   @default(1)
  lastIncomeAt    DateTime              @default(now())
  purchasedAt     DateTime              @default(now())
  countryId       String                @db.VarChar(50)
  propertyId      String                @unique @db.VarChar(100)
  drugProductions DrugProduction[]
  nightclub       NightclubVenue?
  player          Player?               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drugStorage     PropertyDrugStorage[]

  @@index([playerId])
  @@index([propertyType])
  @@index([countryId])
  @@map("properties")
}

model PropertyDrugStorage {
  id         Int      @id @default(autoincrement())
  propertyId Int
  drugType   String   @db.VarChar(50)
  quantity   Int      @default(0)
  storedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, drugType])
  @@index([propertyId])
  @@map("property_drug_storage")
}

model Crew {
  id                    Int                        @id @default(autoincrement())
  mollieSubscriptionId  String?                    @db.VarChar(255)
  stripeSubscriptionId  String?                    @db.VarChar(255)
  name                  String                     @unique @db.VarChar(50)
  bankBalance           Int                        @default(0)
  createdAt             DateTime                   @default(now())
  isVip                 Boolean                    @default(false)
  vipExpiresAt          DateTime?
  ammoInventory         CrewAmmoInventory[]
  ammoStorageBuilding   CrewAmmoStorageBuilding?
  boatInventory         CrewBoatInventory[]
  boatStorageBuilding   CrewBoatStorageBuilding?
  carInventory          CrewCarInventory[]
  carStorageBuilding    CrewCarStorageBuilding?
  cashStorageBuilding   CrewCashStorageBuilding?
  drugInventory         CrewDrugInventory[]
  drugStorageBuilding   CrewDrugStorageBuilding?
  heistAttempts         CrewHeistAttempt[]
  hqBuilding            CrewHqBuilding?
  joinRequests          CrewJoinRequest[]
  members               CrewMember[]
  messages              CrewMessage[]
  weaponInventory       CrewWeaponInventory[]
  weaponStorageBuilding CrewWeaponStorageBuilding?

  @@index([name])
  @@map("crews")
}

model CrewMember {
  id         Int      @id @default(autoincrement())
  crewId     Int
  playerId   Int      @unique
  role       String   @db.VarChar(20)
  joinedAt   DateTime @default(now())
  trustScore Int      @default(50)
  crew       Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([crewId, playerId])
  @@index([playerId])
  @@index([crewId])
  @@map("crew_members")
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      String   @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  addressee   Player   @relation("FriendReceived", fields: [addresseeId], references: [id], onDelete: Cascade)
  requester   Player   @relation("FriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

model DirectMessage {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  message    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   Player   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     Player   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([read])
  @@index([createdAt])
  @@map("direct_messages")
}

model CrewMessage {
  id        Int      @id @default(autoincrement())
  crewId    Int
  playerId  Int
  message   String   @db.Text
  createdAt DateTime @default(now())
  crew      Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([crewId])
  @@index([playerId])
  @@index([createdAt])
  @@map("crew_messages")
}

model CrewJoinRequest {
  id        Int      @id @default(autoincrement())
  crewId    Int
  playerId  Int
  status    String   @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  crew      Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([crewId, playerId])
  @@index([crewId])
  @@index([playerId])
  @@index([status])
  @@map("crew_join_requests")
}

model CrewHeistAttempt {
  id        Int      @id @default(autoincrement())
  crewId    Int
  heistId   String   @db.VarChar(50)
  success   Boolean
  createdAt DateTime @default(now())
  crew      Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@index([crewId])
  @@index([heistId])
  @@index([createdAt])
  @@map("crew_heist_attempts")
}

model CrewHqBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_hq_buildings")
}

model CrewCarStorageBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_car_storage_buildings")
}

model CrewBoatStorageBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_boat_storage_buildings")
}

model CrewWeaponStorageBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_weapon_storage_buildings")
}

model CrewAmmoStorageBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_ammo_storage_buildings")
}

model CrewDrugStorageBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_drug_storage_buildings")
}

model CrewCashStorageBuilding {
  id        Int               @id @default(autoincrement())
  crewId    Int               @unique
  style     CrewBuildingStyle @default(camping)
  level     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  crew      Crew              @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@map("crew_cash_storage_buildings")
}

model CrewCarInventory {
  id              Int      @id @default(autoincrement())
  crewId          Int
  vehicleId       String   @db.VarChar(100)
  condition       Int      @default(100)
  fuelLevel       Int      @default(100)
  stolenInCountry String?  @db.VarChar(50)
  addedByPlayerId Int
  addedAt         DateTime @default(now())
  crew            Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@index([crewId])
  @@map("crew_car_inventory")
}

model CrewBoatInventory {
  id              Int      @id @default(autoincrement())
  crewId          Int
  vehicleId       String   @db.VarChar(100)
