  inapp_crypto_trade       Boolean  @default(true)
  inapp_crypto_price_alert Boolean  @default(true)
  inapp_crypto_order       Boolean  @default(true)
  inapp_crypto_mission     Boolean  @default(true)
  created_at               DateTime @default(now()) @db.DateTime(0)
  updated_at               DateTime @default(now()) @db.DateTime(0)
  push_crypto_leaderboard  Boolean  @default(true)
  inapp_crypto_leaderboard Boolean  @default(true)
  players                  Player   @relation(fields: [player_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_notification_preferences_player")
}

model player_vehicle_parts {
  player_id        Int      @id
  car_parts        Int      @default(0)
  motorcycle_parts Int      @default(0)
  boat_parts       Int      @default(0)
  updated_at       DateTime @default(now()) @db.DateTime(0)
}

model smuggling_shipments {
  id                  Int       @id @default(autoincrement())
  player_id           Int
  category            String    @db.VarChar(20)
  item_key            String    @db.VarChar(100)
  item_label          String    @db.VarChar(120)
  quantity            Int
  unit_tag            String    @default("unit") @db.VarChar(20)
  origin_country      String    @db.VarChar(50)
  destination_country String    @db.VarChar(50)
  status              String    @default("in_transit") @db.VarChar(20)
  metadata_json       String?   @db.LongText
  seizure_chance      Decimal   @default(0.0500) @db.Decimal(6, 4)
  shipping_fee        Int       @default(0)
  eta_at              DateTime  @db.DateTime(0)
  created_at          DateTime  @default(now()) @db.DateTime(0)
  delivered_at        DateTime? @db.DateTime(0)
  claimed_at          DateTime? @db.DateTime(0)
  crew_id             Int?
  channel             String    @default("package") @db.VarChar(20)
  network_scope       String    @default("personal") @db.VarChar(20)

  @@index([player_id, category], map: "idx_smuggling_player_category")
  @@index([player_id, eta_at], map: "idx_smuggling_player_eta")
  @@index([player_id, status, destination_country], map: "idx_smuggling_player_status_country")
}

model vehicle_repair_jobs {
  id                   Int       @id @default(autoincrement())
  player_id            Int
  vehicle_inventory_id Int
  repair_cost          Int
  from_condition       Int
  target_condition     Int       @default(100)
  status               String    @default("in_progress") @db.VarChar(20)
  started_at           DateTime  @default(now()) @db.DateTime(0)
  completes_at         DateTime  @db.DateTime(0)
  completed_at         DateTime? @db.DateTime(0)

  @@index([player_id, status], map: "idx_vehicle_repair_jobs_player_status")
  @@index([vehicle_inventory_id, status], map: "idx_vehicle_repair_jobs_vehicle_status")
}

model vehicle_tuning_upgrades {
  id                   Int       @id @default(autoincrement())
  player_id            Int
  vehicle_inventory_id Int       @unique(map: "uq_vehicle_tuning_vehicle")
  speed_level          Int       @default(0)
  stealth_level        Int       @default(0)
  armor_level          Int       @default(0)
  created_at           DateTime  @default(now()) @db.DateTime(0)
  updated_at           DateTime  @default(now()) @db.DateTime(0)
  tune_cooldown_until  DateTime? @db.DateTime(0)

  @@index([player_id], map: "idx_vehicle_tuning_player")
}

